# Copy to .env and fill in. NEVER commit your real .env file.

# Data source for the dashboard/scanner: "mock" (offline, default) or
# "tradier" (real market data; requires TRADIER_API_TOKEN below).
#KOB_SOURCE=mock

# Automated run loop (serve --run). The deploy start command enables it; set
# KOB_RUN=0 to serve the dashboard only, or KOB_RUN=1 to force it on. The loop
# is market-hours aware (weekdays 9:30-16:00 ET, US holidays excluded).
#KOB_RUN=1

# Tradier API (use the sandbox first!)
# Sandbox base URL: https://sandbox.tradier.com/v1
# Production base URL: https://api.tradier.com/v1
TRADIER_API_TOKEN=your_sandbox_token_here
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Optional hosted Postgres (e.g. Supabase). Grab the exact URI from
# Supabase: Project settings -> Database -> Connection string (URI).
# If your password contains special characters (@ : / ? # etc.) they must be
# percent-encoded in the URI (for example, '@' becomes '%40').
# Direct connection:
#   postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Pooler (recommended for Railway / serverless):
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#DATABASE_URL=